APP_NAME=YandexReviewsConnector
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://45.140.167.90

# SPA и API на одном origin (через nginx), HTTP (без домена/HTTPS).
FRONTEND_URL=http://45.140.167.90
SANCTUM_STATEFUL_DOMAINS=45.140.167.90
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=reviews
DB_USERNAME=reviews
DB_PASSWORD=__SET_ON_SERVER__

SESSION_DRIVER=database
SESSION_LIFETIME=120

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=database

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- Yandex Maps parser ---
YANDEX_PARSER_TIMEOUT=90
YANDEX_PARSER_MAX_REVIEWS=700
YANDEX_PARSER_REQUEST_DELAY_MS=600
YANDEX_PARSER_MAX_ITERATIONS=80
YANDEX_PARSER_PAGE_SIZE=50
YANDEX_PARSER_BROWSER_FALLBACK=true
YANDEX_PARSER_USE_FIXTURES=false
