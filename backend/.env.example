APP_NAME=YandexReviewsConnector
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

FRONTEND_URL=http://localhost:5173
SANCTUM_STATEFUL_DOMAINS=localhost:5173,127.0.0.1:5173

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=reviews
DB_USERNAME=reviews
DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=localhost

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=database

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# --- Yandex Maps parser ---
# Таймаут сетевого запроса, сек.
YANDEX_PARSER_TIMEOUT=60
# Верхняя граница количества загружаемых отзывов.
YANDEX_PARSER_MAX_REVIEWS=700
# Пауза между запросами к источнику, мс.
YANDEX_PARSER_REQUEST_DELAY_MS=500
# Защита от бесконечного цикла парсинга.
YANDEX_PARSER_MAX_ITERATIONS=60
# Размер страницы при обходе внутреннего API отзывов.
YANDEX_PARSER_PAGE_SIZE=50
# Включить headless-browser fallback (требует Playwright, см. README).
YANDEX_PARSER_BROWSER_FALLBACK=true
# true — брать данные из локальных fixtures (гарантированное демо без доступа к Яндексу).
YANDEX_PARSER_USE_FIXTURES=false
